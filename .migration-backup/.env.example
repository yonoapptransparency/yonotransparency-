# REQUIRED — server cannot decrypt download links without this.
# Must match the key used to encrypt links in the Admin Dashboard.
# DO NOT leave blank. Generate: openssl rand -hex 32
AES_SECRET=REPLACE_WITH_YOUR_REAL_KEY

# REQUIRED in production. Randomises per restart if not set (tokens break on redeploy).
# Generate: openssl rand -hex 32
TOKEN_SECRET=REPLACE_WITH_YOUR_REAL_KEY

# Optional — Cloudflare Turnstile. Leave blank to disable.
CF_TURNSTILE_SECRET=
VITE_CF_TURNSTILE_SITE_KEY=

# Optional — Administrator configuration. Defaults to defentechscholar@gmail.com if not specified.
ADMIN_EMAIL=
VITE_ADMIN_EMAIL=

VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_ID=
