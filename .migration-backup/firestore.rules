rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ID checking helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidAdminId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-@.]+$');
    }

    // Helper to verify if user is authorized as an admin (via database index lookup or owner fallback)
    // Checks that the email is verified to prevent unverified email spoofing attacks
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email_verified == true &&
             (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
              exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
    }

    // Comprehensive payload validation for reviews
    function isValidReview(data) {
      return data.keys().hasAll(['app_id', 'username', 'rating', 'comment', 'created_at', 'helpful_count', 'is_approved', 'source']) &&
             data.keys().size() == 8 &&
             data.app_id is string && data.app_id.size() <= 128 &&
             data.username is string && data.username.size() <= 200 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 2000 &&
             data.created_at is string && data.created_at.size() <= 64 &&
             data.helpful_count is number &&
             data.is_approved is bool &&
             data.source is string && data.source.size() <= 128;
    }

    // Comprehensive payload validation for website feedback
    function isValidFeedback(data) {
      return data.keys().hasAll(['username', 'rating', 'comment', 'created_at', 'source']) &&
             data.keys().size() == 5 &&
             data.username is string && data.username.size() <= 200 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 2000 &&
             data.created_at is string && data.created_at.size() <= 64 &&
             data.source is string && data.source.size() <= 128;
    }

    // Comprehensive payload validation for support tickets
    function isValidTicket(data) {
      return data.keys().hasAll(['username', 'email', 'comment', 'created_at', 'status', 'source']) &&
             data.keys().size() == 6 &&
             data.username is string && data.username.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.comment is string && data.comment.size() <= 3000 &&
             data.created_at is string && data.created_at.size() <= 64 &&
             data.status is string && data.status.size() <= 64 &&
             data.source is string && data.source.size() <= 128;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public reading of non-sensitive store data and encrypted secure links
    // Restrict sensitive vault maps, links, and git config strictly to authorized administrators
    match /store_data/{docId} {
      allow read: if isValidId(docId) && (
        (docId != 'sec_git_config' && docId != 'secure_links' && docId != 'sec_vault') || isAdmin()
      );
      allow write: if isAdmin();
    }
    
    // Support for metadata or other collections if they exist
    match /sec_git/{docId} {
      allow read, write: if isValidId(docId) && isAdmin();
    }

    match /apps/{appId} {
      allow read: if true;
      allow write: if isValidId(appId) && isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidId(reviewId) && isValidReview(request.resource.data) && (request.resource.data.is_approved == false || isAdmin());
      allow update: if isValidId(reviewId) && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reported', 'report_count']) || isAdmin());
      allow delete: if isValidId(reviewId) && isAdmin();
    }
    
    match /admins/{docId} {
      allow read: if request.auth != null && (request.auth.uid == docId || (request.auth.token.email_verified == true && request.auth.token.email == docId) || isAdmin());
      allow write: if isValidAdminId(docId) && isAdmin();
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && isValidId(userId) && request.auth.uid == userId;
    }

    match /missing_link_reports/{reportId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /website_feedback/{feedbackId} {
      allow create: if isValidId(feedbackId) && isValidFeedback(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow create: if request.auth != null && isValidId(ticketId) && isValidTicket(request.resource.data);
      allow read, update, delete: if isAdmin();
    }
  }
}
