rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'defentechscholar@gmail.com';
    }

    // Public site data
    match /store_data/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for others, but admin has god mode
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
