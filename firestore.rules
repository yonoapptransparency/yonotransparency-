rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is the specific admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'defentechscholar@gmail.com' &&
             request.auth.token.email_verified == true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public reading of all store data
    // Only allow the admin to write/update
    match /store_data/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Support for metadata or other collections if they exist
    match /apps/{appId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
