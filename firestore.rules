rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to verify if user is authorized as an admin (via database index lookup or owner fallback)
    function isAdmin() {
      return request.auth != null && 
             (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
              exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) ||
              request.auth.token.email == 'defentechscholar@gmail.com');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public reading of all store data
    // Only allow the admin to write/update
    match /store_data/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Support for metadata or other collections if they exist
    match /secure_git_config/{docId} {
      allow read, write: if isAdmin();
    }

    match /apps/{appId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
